APP_NAME=oracle-migration-app
APP_VERSION=0.1.0
APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://app_user:change_me@postgres:5432/oracle_migration_app
REDIS_BROKER_URL=redis://redis:6379/0
REDIS_RESULT_BACKEND=redis://redis:6379/1
TASK_ALWAYS_EAGER=false
DATAPUMP_ENABLED=false
DATAPUMP_EXECUTION_BACKEND=auto
DATAPUMP_EXPDP_PATH=/opt/oracle-tools/expdp
DATAPUMP_IMPDP_PATH=/opt/oracle-tools/impdp
DATAPUMP_WORK_DIR=/var/lib/oracle-migration/datapump
DATAPUMP_CALL_TIMEOUT_SECONDS=43200
OTEL_ENABLED=true
OTEL_EXPORTER=console
OTEL_ENVIRONMENT=production
OTEL_SERVICE_NAMESPACE=oracle-migration
FRONTEND_PUBLIC_API_BASE_URL=/api/v1
POSTGRES_DB=oracle_migration_app
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_me
